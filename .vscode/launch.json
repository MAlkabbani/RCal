{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RCal: main.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "RCal: unittest",
      "type": "python",
      "request": "launch",
      "module": "unittest",
      "args": [
        "test_main",
        "-v"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
