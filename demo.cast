[0.000, "o", "81;189mSalary 25%\u001b[0m\u001b[38;2;173;181;189m   \u001b[0m\u001b[38;2;231;111;81m█ \u001b[0m\u001b[38;2;173;181;189mINSS 3%\u001b[0m\u001b[38;2;173;181;189m   \u001b[0m\u001b[38;2;230;57;70m█ \u001b[0m\u001b[38;2;173;181;189mDAS 3%\u001b[0m\u001b[38;2;173;181;189m   \u001b[0m\u001b[38;2;46;196;182m█ \u001b[0m\u001b[38;2;173;181;189mYours 69%\u001b[0m  \u001b[1;38;2;0;180;216m│\u001b[0m                                    \r\n                                   \u001b[1;38;2;0;180;216m│\u001b[0m                                                       \u001b[1;38;2;0;180;216m│\u001b[0m                                    \r\n                                   \u001b[1;38;2;0;180;216m╰───────────────────────────────────────────────────────╯\u001b[0m                                    \r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[38;2;69;123;157m───────────────────────────────────────────────────────── \u001b[0m💡 Strategy\u001b[38;2;69;123;157m ──────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.001, "o", "\u001b[38;2;173;181;189m  Paying ≥28% of gross as salary keeps you in Anexo III (~6%) instead of Anexo V (~15.5%).\u001b[0m\r\n\u001b[38;2;173;181;189m  The ideal Pró-labore is the minimum needed to maintain this threshold while respecting the legal minimum wage.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[38;2;69;123;157m─────────────────────────────────────────────────────── \u001b[0m💱 Exchange Rate\u001b[38;2;69;123;157m ───────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;173;181;189m  Use the BRL rate on the date the funds are made available or the invoice is issued — not the withdrawal date.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[38;2;69;123;157m──────────────────────────────────────────────────────── \u001b[0m⚖️  Disclaimer\u001b[38;2;69;123;157m ────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;173;181;189m  Estimates for planning purposes only. PGDAS-D and DAS filings still depend on rolling 12-month revenue, payroll history, and \u001b[0m\r\n\u001b[38;2;173;181;189mmunicipal licensing facts. Always consult a qualified Brazilian accountant (contador) for official filings.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
