[0.002, "o", "\u001b[38;2;69;123;157m───────────────────────────────────────────────────────── \u001b[0m💡 Strategy\u001b[38;2;69;123;157m ──────────────────────────────────────────────────────────\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;173;181;189m  Paying ≥28% of gross as salary keeps you in Anexo III (~6%) instead of Anexo V (~15.5%).\u001b[0m\r\n\u001b[38;2;173;181;189m  The ideal Pró-labore is the minimum needed to maintain this threshold while respecting the legal minimum wage.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[38;2;69;123;157m─────────────────────────────────────────────────────── \u001b[0m💱 Exchange Rate\u001b[38;2;69;123;157m ───────────────────────────────────────────────────────\u001b[0m\r\n"]
